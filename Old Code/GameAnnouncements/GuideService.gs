/**
 * Service responsible for providing educational content and character templates.
 * Implements a static knowledge base for players.
 */
class GuideService {
    /**
     * Returns the main keyboard for the guide.
     */
    static getGuideKeyboard() {
        return [
            [{ text: "🎲 Что такое D&D?", callback_data: "guide_what_is_dnd" }],
            [{ text: "👤 Как создать персонажа?", callback_data: "guide_create_char" }],
            [{ text: "📊 Характеристики и модификаторы", callback_data: "guide_stats" }],
            [{ text: "📐 Магия костей и Урон", callback_data: "guide_dice" }],
            [{ text: "📝 Получить шаблон анкеты", callback_data: "guide_template" }]
        ];
    }

    /**
     * Returns the character template string with a structured example.
     * @returns {string}
     * @public
     */
    static getCharacterTemplate() {
        return `<code>Имя: \n` +
               `Класс: \n` +
               `Раса: \n` +
               `ХП: \n` +
               `Класс брони: \n` +
               `Возраст (опц.*): \n` +
               `Пол (опц.*): \n` +
               `Характер (опц.*): \n` +
               `Внешность (опц.*): \n` +
               `Предыстория (опц.*): \n\n` +
               `Характеристики:\n` +
               `Сила: \n` +
               `Ловкость: \n` +
               `Выносливость: \n` +
               `Интеллект: \n` +
               `Мудрость: \n` +
               `Харизма: \n\n` +
               `Бафы/Дебафы (опц.*): \n` +
               `Инвентарь: \n\n` +
               `Скиллы (Название | Описание | Эффект):\n` +
               `1. \n` +
               `2. \n\n` +
               `Пример заполнения скилла:\n` +
               `Название: Fireball \n` +
               `Описание: Создает огненный шар в ладони и выпускает во врага \n` +
               `Эффект: Урон 1d12 + 1d6 + Мод. Интеллекта</code>\n\n` +
               `<i>* — опциональные пункты уточняются у вашего ГМа.</i>`;
    }

    /**
     * Gets specific content based on the topic.
     */
    static getContent(topic) {
        const database = {
            "guide_what_is_dnd": 
                "<b>🎲 Что такое D&D? Это твоя личная эпическая сага!</b>\n\n" +
                "Представь, что ты — главный герой фильма или компьютерной игры, но здесь нет невидимых стен и скриптов. <b>Dungeons & Dragons</b> — это мир бесконечных возможностей, где единственное ограничение — твоя фантазия.\n\n" +
                "⚔️ <b>Как это работает?</b>\n" +
                "Мастер игры (ГМ) создает декорации: мрачное подземелье, шумную таверну или тронный зал короля. Ты решаешь, что делать. Хочешь выбить дверь ногой? Попробовать договориться с разбойниками? Или обрушить на врагов огненный шквал? <b>Просто скажи об этом!</b>\n\n" +
                "🎲 <b>Судьба в твоих руках (и в кубиках)</b>\n" +
                "Твои навыки — это <b>6 характеристик</b> (Сила, Ловкость и др.). Когда ты совершаешь сложное действие, ты бросаешь двадцатигранный кубик (d20). Твои статы прибавляются к результату, и если сумма высока — ты совершаешь невозможное!\n\n" +
                "🛡 <b>Почему это круто?</b>\n" +
                "• <b>Уникальность:</b> Твой персонаж растет, находит артефакты и заводит союзников.\n" +
                "• <b>Живой мир:</b> Твои решения меняют ход истории. Ты можешь спасти деревню или стать ее лордом.\n" +
                "• <b>Команда:</b> Ты играешь с друзьями, где каждый важен — от могучего воина до хитрого плута.\n\n" +
                "<i>Готов ли ты бросить свой первый кубик и войти в историю? Приключения ждут!</i>",

            "guide_create_char": 
                "<b>👤 Создание персонажа: Пошаговый алгоритм</b>\n\n" +
                "1. <b>Концепт:</b> Кто ты в этом мире? \n" +
                "Подумай о синергии. <i>Полуорк-Варвар</i> — это мощь, а <i>Эльф-Маг</i> — это острый ум.\n\n" +
                "2. <b>Распределение характеристик (Point Buy):</b>\n" +
                "Базово все твои характеристики равны <b>0</b>. Тебе дается <b>6 свободных очков</b>.\n" +
                "• <b>+1 очко:</b> увеличивает характеристику на 1.\n" +
                "• <b>Механика штрафа:</b> Ты можешь снизить стат до <b>-2</b>, чтобы получить <b>+1 дополнительное очко</b> в банк.\n" +
                "• <b>Лимит:</b> Максимально допустимый штраф обычно <b>-3</b>, но это <i>уточняется у твоего ГМа</i>.\n\n" +
                "📐 <b>Пример расчета (на Сильного Воина):</b>\n" +
                "У тебя было 6 очков. Ты решил, что твой Воин не очень умный, и поставил <b>Интеллект: -2</b>. За это ты получил +1 очко в банк. Теперь у тебя 7 очков (6+1).\n" +
                "Все 7 очков ты вложил в Силу.\n\n" +
                "<b>В анкете это будет выглядеть так:</b>\n" +
                "<code>Сила: 7\n" +
                "Интеллект: -2\n" +
                "Ловкость: 0\n" +
                "Мудрость: 0\n" +
                "Выносливость: 0\n" +
                "Харизма: 0</code>\n\n" +
                "3. <b>Внешность и Личность (Опционально):</b>\n" +
                "Пол, возраст, внешность и характер. Эти пункты не влияют на броски, но делают героя живым. Заполняй <b>по желанию</b>.",

            "guide_stats": 
                "<b>📊 Твои возможности: Характеристики и Модификаторы</b>\n\n" +
                "Характеристики показывают, на что способен твой герой. Чем выше число, тем больше твой <b>Модификатор</b> — бонус, который ты прибавляешь к кубику d20.\n\n" +
                "🛡 <b>За что отвечает каждая характеристика?</b>\n" +
                "• <b>Сила:</b> Твоя мощь. Нужна, чтобы выломать дубовую дверь, поднять упавшую решетку или прыгнуть через расщелину.\n" +
                "• <b>Ловкость:</b> Твоя реакция и скрытность. Помогает увернуться от летящей стрелы, бесшумно пройти мимо стражи или взломать сложный замок.\n" +
                "• <b>Выносливость:</b> Стойкость организма. Помогает пережить отравление ядом, сильное опьянение, долгое утопление или изнурительный марш (<i>на количество ХП не влияет</i>).\n" +
                "• <b>Интеллект:</b> Твоя память и логика. Помогает вспомнить древнюю историю, расшифровать магические руны или найти слабые места в механизме.\n" +
                "• <b>Мудрость:</b> Твоя интуиция и внимательность. Помогает заметить засаду в кустах, почувствовать ложь в словах или вылечить раненого товарища.\n" +
                "• <b>Харизма:</b> Твое влияние. Нужна, чтобы убедить короля помочь вам, запугать разбойника или выторговать скидку у жадного купца.\n\n" +
                "✨ <b>Как работает Модификатор в бою?</b>\n" +
                "Это твой «профессиональный бонус». Например, если ты Маг, твоя <b>Основная характеристика</b> — Интеллект. \n\n" +
                "Когда ты используешь заклинание (допустим, наш <i>Fireball</i>), к броску урона прибавляется твой бонус за Интеллект. \n" +
                "<b>Формула выглядит так:</b>\n" +
                "<code>[Кубики урона] + [Модификатор твоей главной характеристики]</code>\n\n" +
                "<i>То есть, чем умнее твой Маг, тем жарче горит его пламя! То же самое у Воина с Силой при ударе мечом.</i>",

            "guide_dice": 
                "<b>📐 Магия костей: Как понять, что ты победил?</b>\n\n" +
                "Запомни простое правило: <b>d20 — это ШАНС, а остальные кости — это СИЛА.</b>\n\n" +
                "1️⃣ <b>Проверка сложности (КС / DC)</b>\n" +
                "Когда ты хочешь что-то сделать (вскрыть замок, прыгнуть, обмануть стражу), ГМ назначает <b>Сложность</b>. Твоя задача — выбросить на d20 + модификатор число <u>равное или больше</u> этой сложности.\n\n" +
                "• <b>5 — Очень просто:</b> Толкнул незапертую дверь.\n" +
                "• <b>10 — Легко:</b> Запрыгнул на невысокий забор.\n" +
                "• <b>15 — Средне:</b> Вскрыл обычный сундук.\n" +
                "• <b>20 — Трудно:</b> Убедил стражника, что ты — его троюродная тетя.\n" +
                "• <b>25+ — Почти невозможно:</b> Поднял упавшую каменную колонну.\n\n" +
                "2️⃣ <b>Встречные проверки (Ты против Врага)</b>\n" +
                "Если ты борешься с кем-то (например, толкаешь орка), вы оба кидаете d20 + статы. <b>Побеждает тот, у кого число выше.</b> При ничьей ситуация обычно не меняется.\n\n" +
                "3️⃣ <b>Расчет Урона (После попадания)</b>\n" +
                "Если твой бросок на d20 преодолел <i>Класс Брони</i> врага, ты кидаешь кости урона:\n" +
                "• <b>d20:</b> Попал или нет (Шанс).\n" +
                "• <b>d4, d6, d8, d10, d12:</b> Насколько больно ты ударил (Сила).\n\n" +
                "<b>Пример:</b> Ты бьешь мечом. ГМ говорит: «У врага броня 12». \n" +
                "Ты кидаешь d20, выпадает 10. Твоя Сила +3. Итого <b>13</b>. \n" +
                "<i>13 >= 12? Да!</i> Теперь кидай d8 на урон! ⚔️",
        };
        
        return database[topic] || "Информация уточняется...";
    }

    /**
     * Returns the welcome message for the /start command.
     * @param {string} firstName - User's first name.
     * @returns {string}
     */
    static getWelcomeMessage(firstName) {
        return `🌟 <b>Приветствуем тебя, путник ${firstName}!</b>\n\n` +
               `Добро пожаловать в <b>VRode_DnD_20</b> — уютное и ламповое сообщество, где оживают легенды! 🎲✨\n\n` +
               `🛡 <b>Кто мы такие?</b>\n` +
               `Мы — объединение любителей настольных ролевых игр, мафии и просто хорошего общения. Здесь ценят юмор, креатив и уважение друг к другу. \n\n` +
               `⚔️ <b>Кого мы ищем?</b>\n` +
               `• Веселых авантюристов, готовых к безумным планам.\n` +
               `• Новичков, которые хотят бросить свой первый d20.\n` +
               `• Мастеров, мечтающих воплотить свои миры в жизнь.\n\n` +
               `🔮 <b>Твоё приключение начинается здесь:</b>\n` +
               `Если ты готов стать частью нашей истории, завести верных союзников и найти партию по душе — не медли!\n\n` +
               `<i>Жми на кнопку ниже и вступай в наше дружное братство!</i>`;
    }

    /**
     * Returns the inline keyboard for the start message.
     * @returns {Array[]}
     */
    static getStartKeyboard() {
        return [
            [{ text: "⚔️ Вступить в группу VRode_DnD_20", url: "https://t.me/+Pfg1-dxoPsZmNWEy" }]
        ];
    }

    /**
     * Returns a detailed message for banned users.
     * @returns {string}
     */
    static getBannedMessage() {
        return `🚫 <b>Доступ ограничен</b>\n\n` +
               `К сожалению, ваш аккаунт был заблокирован в системе <b>VRode_DnD_20</b>.\n\n` +
               `<b>Что это значит?</b>\n` +
               `• Вы не можете вступить в наше сообщество.\n` +
               `• Вам закрыт доступ к регистрации на игры (D&D, Мафия).\n` +
               `• Ваши заявки будут отклоняться автоматически.\n\n` +
               `<b>Почему это могло произойти?</b>\n` +
               `Обычно бан выдается за систематическое нарушение правил, неподобающее поведение или получение максимального количества предупреждений (2/2).\n\n` +
               `<i>Если вы считаете, что произошла ошибка, свяжитесь с администратором.</i>`;
    }
}