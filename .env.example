NODE_ENV=production
PORT=3000
HOST=0.0.0.0

TELEGRAM_BOT_TOKEN=replace_with_real_bot_token
TELEGRAM_ALLOWED_ADMIN_IDS=
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_GROUP_INVITE_URL=https://t.me/your_group_invite
TELEGRAM_CANDIDATE_BOT_USERNAME=vr_partyAdmin_bot
TELEGRAM_CANDIDATE_BOT_API_URL=

MAIN_CHAT_ID=0
GENERAL_CHAT_ID=0
ANNOUNCEMENT_TOPIC_ID=0
LEADERBOARD_CHAT_ID=0
LEADERBOARD_THREAD_ID=0
LEADERBOARD_MSG_ID=0
ADMIN_CHAT_ID=0
ADMIN_TOPIC_ID=0

DATABASE_PATH=./data/app.db
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Bot control block in admin panel:
# systemd mode (Linux VPS): BOT_CONTROL_MODE=systemd and service name
# custom mode: leave BOT_CONTROL_MODE empty and set commands below manually
BOT_CONTROL_MODE=systemd
BOT_CONTROL_SERVICE_NAME=telegram-bot
BOT_CONTROL_CMD_STATUS=
BOT_CONTROL_CMD_START=
BOT_CONTROL_CMD_STOP=
BOT_CONTROL_CMD_RESTART=
BOT_CONTROL_CMD_UPDATE=
